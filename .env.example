# ==============================
# Server
# ==============================
# Porta em que o servidor HTTP vai escutar
PORT=8080

# ==============================
# Database (PostgreSQL)
# ==============================
# String de conexão completa do Postgres
# Formato: postgres://usuario:senha@host:porta/nome_do_banco?sslmode=disable
DATABASE_URL=postgres://user:pass@localhost:5432/azgher?sslmode=disable

# Número máximo de conexões abertas simultaneamente com o banco
DB_MAX_OPEN_CONNS=25

# Número máximo de conexões ociosas mantidas no pool
DB_MAX_IDLE_CONNS=5

# ==============================
# Auth / JWT
# ==============================
# Segredo usado para assinar os tokens JWT (mínimo 32 caracteres)
JWT_SECRET=change-this-to-a-random-secret-with-32-chars-min

# ==============================
# Google OAuth
# ==============================
# Credenciais obtidas no Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
